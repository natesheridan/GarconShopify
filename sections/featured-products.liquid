{%- if section.settings.collection != blank -%}
  {%- assign featured_collection = collections[section.settings.collection] -%}
{%- endif -%}

<section class="featured-products">
  <div class="featured-header">
    <h2 class="featured-heading">{{ section.settings.heading | default: 'Drop' }}</h2>
    <div class="featured-meta">
      <p>
        {%- if featured_collection -%}
          {{ featured_collection.products_count }} PIECES
        {%- else -%}
          CURRENT DROP
        {%- endif -%}
      </p>
      <a href="{{ routes.collections_url }}" class="featured-all">View all &rarr;</a>
    </div>
  </div>

  <div class="product-grid{% if section.settings.product_limit == 2 %} product-grid--2col{% endif %}">
    {%- if featured_collection -%}
      {%- for product in featured_collection.products limit: section.settings.product_limit -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.product_limit) -%}
        <div class="product-card">
          <div class="product-card__img-wrap" style="background:var(--ash);aspect-ratio:2/3;"></div>
          <div class="product-card__info">
            <span class="product-card__name" style="opacity:0.18">PRODUCT {{ i }}</span>
            <span class="product-card__price" style="opacity:0.18">—</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Drop" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "min": 2, "max": 3, "step": 1, "label": "Number of products", "default": 3 }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

<div class="collection-page">
  <div class="collection-page__header">
    <h1 class="collection-page__title">{{ collection.title | upcase }}</h1>
    <p class="collection-page__count">{{ collection.products_count }} items</p>
  </div>

  <div class="collection-toolbar">
    <div class="collection-search">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input type="search" placeholder="Search..." aria-label="Search products">
    </div>

    <select class="filter-select" aria-label="Filter by type">
      <option value="all">All</option>
      {%- for type in collection.all_types -%}
        {%- unless type == blank -%}
          <option value="{{ type }}">{{ type | upcase }}</option>
        {%- endunless -%}
      {%- endfor -%}
    </select>

    <select class="filter-select" name="sort_by" aria-label="Sort by" onchange="window.location.search = '?sort_by=' + this.value">
      <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>Featured</option>
      <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price ↑</option>
      <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price ↓</option>
      <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
    </select>
  </div>

  <div class="product-list">
    {%- for product in collection.products -%}
      <a class="product-list-row" href="{{ product.url }}">
        {%- if product.featured_image -%}
          <img
            class="product-list-row__thumb"
            src="{{ product.featured_image | image_url: width: 140 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="70"
            height="70"
            loading="lazy"
          >
        {%- else -%}
          <div class="product-list-row__thumb" style="background:var(--ash);"></div>
        {%- endif -%}

        <div class="product-list-row__info">
          <p class="product-list-row__name">{{ product.title | upcase }}</p>
          {%- if product.type != blank -%}
            <span class="product-list-row__type">{{ product.type | upcase }}</span>
          {%- endif -%}
        </div>

        <p class="product-list-row__price">{{ product.price | money }}</p>

        <div class="product-list-row__arrow" aria-hidden="true">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    {%- else -%}
      <p class="collection-empty">No products found.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="collection-pagination">
      {%- for i in (1..paginate.pages) -%}
        <a
          href="?page={{ i }}"
          class="collection-pagination__page{% if i == paginate.current_page %} is-active{% endif %}"
        >{{ i }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}

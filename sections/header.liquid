<header class="site-header" id="site-header">
  <button class="menu-toggle" aria-label="Open navigation menu" aria-controls="mobile-nav" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
    <!-- Clip container: full header height, overflow hidden — logo overflows top/bottom intentionally -->
    <div class="site-header__logo-clip">
      <img
        id="site-logo-img"
        class="site-header__logo-img"
        src="{{ 'garcon-logo-white.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="140"
        height="140"
        loading="eager"
      >
    </div>
  </a>

  <nav class="site-header__nav" id="mobile-nav" aria-label="Primary navigation">
    {%- for link in linklists[section.settings.menu].links -%}
      <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
        {{- link.title | upcase -}}
      </a>
    {%- endfor -%}
  </nav>

  <div class="site-header__actions">
    <a href="{{ routes.cart_url }}" class="cart-link" aria-label="Cart">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>
      </svg>
      <span class="cart-count" style="display:none" aria-label="items in cart">0</span>
    </a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "default": "main-menu", "label": "Navigation menu" }
  ]
}
{% endschema %}

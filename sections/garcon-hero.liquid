<section class="garcon-hero" id="garcon-hero">

  <!-- White flash element -->
  <div class="hero-flash" aria-hidden="true"></div>

  <!-- Atmospheric overlays -->
  <div class="hero-texture" aria-hidden="true"></div>
  <div class="hero-scanlines" aria-hidden="true"></div>

  <!-- Registration corner marks -->
  <div class="hero-corner hero-corner--tl" aria-hidden="true"></div>
  <div class="hero-corner hero-corner--tr" aria-hidden="true"></div>
  <div class="hero-corner hero-corner--bl" aria-hidden="true"></div>
  <div class="hero-corner hero-corner--br" aria-hidden="true"></div>

  <!-- Vertical side labels -->
  <div class="hero-side-label hero-side-label--left" aria-hidden="true">GARCON / SS26</div>
  <div class="hero-side-label hero-side-label--right" aria-hidden="true">001</div>

  <!-- Logo stack: chromatic layers + main -->
  <div class="hero-logo-wrap">
    <div class="hero-logo-glitch-b" aria-hidden="true">
      <img
        src="{{ 'garcon-logo-white.png' | asset_url }}"
        alt=""
        width="1080"
        height="1080"
        loading="eager"
      >
    </div>
    <div class="hero-logo-glitch-r" aria-hidden="true">
      <img
        src="{{ 'garcon-logo-white.png' | asset_url }}"
        alt=""
        width="1080"
        height="1080"
        loading="eager"
      >
    </div>
    <img
      class="hero-logo-main"
      src="{{ 'garcon-logo-white.png' | asset_url }}"
      alt="GARCON"
      width="1080"
      height="1080"
      loading="eager"
    >
  </div>

  <!-- Sub-content: rule + tagline + CTA -->
  <div class="hero-sub">
    <div class="hero-rule" aria-hidden="true"></div>

    {%- if section.settings.tagline != blank -%}
      <p class="hero-tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}

    <span class="hero-sub-label">EST. 2026 — INTERNET DIVISION</span>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="hero-cta">
        {{ section.settings.cta_label }}
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    {%- endif -%}
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>SCROLL</span>
    <div class="hero-scroll-line"></div>
  </div>

</section>

{% schema %}
{
  "name": "GARCON Hero",
  "tag": "section",
  "class": "section-hero",
  "limit": 1,
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Meme apparel for the culturally broken." },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ],
  "presets": [{ "name": "GARCON Hero" }]
}
{% endschema %}

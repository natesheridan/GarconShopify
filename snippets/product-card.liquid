<a class="product-card" href="{{ product.url }}">
  <div class="product-card__image-wrap">
    {%- if product.featured_image -%}
      <img
        class="product-card__image"
        src="{{ product.featured_image | image_url: width: 800 }}"
        alt="{{ product.featured_image.alt | escape }}"
        width="800"
        height="1067"
        loading="lazy"
      >
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--bg-3)"></div>
    {%- endif -%}
  </div>
  <div class="product-card__overlay"></div>

  {%- if product.available == false -%}
    <span class="product-card__badge">Sold Out</span>
  {%- elsif product.tags contains 'new' -%}
    <span class="product-card__badge">New</span>
  {%- endif -%}

  <div class="product-card__info">
    <span class="product-card__name">{{ product.title }}</span>
    <span class="product-card__price">{{ product.price | money }}</span>
  </div>

  <div class="product-card__accent"></div>
</a>

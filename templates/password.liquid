<div class="password-page">

  <!-- Corner ticks -->
  <div class="pw-corner pw-corner--tl" aria-hidden="true"></div>
  <div class="pw-corner pw-corner--tr" aria-hidden="true"></div>
  <div class="pw-corner pw-corner--bl" aria-hidden="true"></div>
  <div class="pw-corner pw-corner--br" aria-hidden="true"></div>

  <div class="password-inner">
    <img
      class="password-logo"
      src="{{ 'garcon-logo-white.png' | asset_url }}"
      alt="{{ shop.name }}"
      width="480"
      height="480"
    >

    <div class="password-text">
      <p class="password-label">RESTRICTED ACCESS</p>
      <p class="password-sub">EST. 2026 — INTERNET DIVISION</p>
    </div>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p class="password-error">Wrong password. Try again.</p>
      {%- endif -%}

      <div class="password-form">
        <input
          type="password"
          name="password"
          class="password-input"
          placeholder="ENTER PASSWORD"
          autocomplete="current-password"
          autofocus
        >
        <button type="submit" class="password-submit">→</button>
      </div>
    {%- endform -%}
  </div>

</div>

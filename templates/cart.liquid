{% layout 'theme' %}

{%- if cart.item_count == 0 -%}
  <div class="cart-page" style="text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:70vh;">
    <p style="font-family:var(--font-display);font-size:80px;color:var(--border);letter-spacing:0.05em;">EMPTY</p>
    <p style="font-size:11px;color:var(--text-3);letter-spacing:0.15em;margin-bottom:28px;margin-top:8px;">Your cart is empty.</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn-ghost">Shop Now</a>
  </div>
{%- else -%}
  <div class="cart-page">
    <h1 class="cart-page__title">Cart</h1>

    <form action="{{ routes.cart_url }}" method="post" novalidate>
      {%- for item in cart.items -%}
        <div class="cart-item">
          <img class="cart-item__img" src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="100" loading="lazy">
          <div class="cart-item__info">
            <p class="cart-item__name">{{ item.product.title }}</p>
            {%- unless item.variant.title == 'Default Title' -%}
              <p class="cart-item__variant">{{ item.variant.title }}</p>
            {%- endunless -%}
            <div class="cart-item__qty">
              <button type="button" class="qty-dec" data-id="{{ item.id }}">&#8722;</button>
              <span>{{ item.quantity }}</span>
              <button type="button" class="qty-inc" data-id="{{ item.id }}">+</button>
              <button type="button" class="qty-remove" data-id="{{ item.id }}" style="margin-left:auto;background:none;border:none;color:var(--text-3);font-size:10px;letter-spacing:0.1em;cursor:pointer;text-transform:uppercase;">Remove</button>
            </div>
          </div>
          <div class="cart-item__price">{{ item.final_line_price | money }}</div>
        </div>
      {%- endfor -%}

      <div class="cart-totals">
        <div class="cart-totals__row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-totals__row" style="font-size:10px;color:var(--text-3);">
          <span>Shipping calculated at checkout</span>
        </div>
        <div class="cart-totals__row cart-totals__row--total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
      </div>

      <button type="submit" name="checkout" class="checkout-btn">
        Checkout
      </button>
    </form>
  </div>

  <script>
    document.querySelectorAll('.qty-dec, .qty-inc, .qty-remove').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const isRemove = btn.classList.contains('qty-remove');
        const isInc = btn.classList.contains('qty-inc');
        const item = btn.closest('.cart-item');
        const qtyEl = item.querySelector('.cart-item__qty span');
        let qty = isRemove ? 0 : parseInt(qtyEl.textContent) + (isInc ? 1 : -1);
        if (qty < 0) qty = 0;
        await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, quantity: qty }),
        });
        location.reload();
      });
    });
  </script>
{%- endif -%}

<div class="nf-page">

  <div class="nf-beams" aria-hidden="true">
    <div class="nf-beam nf-beam--1"></div>
    <div class="nf-beam nf-beam--2"></div>
    <div class="nf-beam nf-beam--3"></div>
  </div>

  <div class="nf-corner nf-corner--tl" aria-hidden="true"></div>
  <div class="nf-corner nf-corner--tr" aria-hidden="true"></div>
  <div class="nf-corner nf-corner--bl" aria-hidden="true"></div>
  <div class="nf-corner nf-corner--br" aria-hidden="true"></div>

  <div class="nf-eye-wrap" id="nf-eye-wrap" aria-hidden="true">
    <div class="nf-eye-outer">
      <div class="nf-eye-blinker" id="nf-blinker">
        <div class="nf-eye-iris">
          <div class="nf-eye-pupil" id="nf-pupil"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="nf-text" id="nf-text">
    <p class="nf-code" aria-label="404">
      <span class="nf-num">4</span><span class="nf-num nf-num--zero" aria-hidden="true">0</span><span class="nf-num">4</span>
    </p>
    <p class="nf-msg">Eye don't know what you're looking for, but this isn't it.</p>
    <a href="{{ routes.root_url }}" class="nf-btn">Go Home</a>
  </div>

</div>

<script>
(function () {
  var eyeWrap = document.getElementById('nf-eye-wrap');
  var blinker = document.getElementById('nf-blinker');
  var pupil   = document.getElementById('nf-pupil');
  var text    = document.getElementById('nf-text');

  function doBlink() {
    blinker.classList.add('nf-blink-anim');
    setTimeout(function () { blinker.classList.remove('nf-blink-anim'); }, 150);
  }

  // Phase 1 — blink
  setTimeout(function () {
    doBlink();

    // Phase 2 — settle (after blink opens back up)
    setTimeout(function () {
      eyeWrap.classList.add('nf-eye--settled');

      // Phase 3 — reveal text
      setTimeout(function () {
        text.classList.add('nf-text--visible');
        scheduleRandomBlink();
      }, 1500);
    }, 350);
  }, 1080);

  // Pupil mouse tracking
  document.addEventListener('mousemove', function (e) {
    var cx = window.innerWidth / 2;
    var cy = window.innerHeight / 2;
    var dx = Math.max(-10, Math.min(10, (e.clientX - cx) / cx * 12));
    var dy = Math.max(-10, Math.min(10, (e.clientY - cy) / cy * 12));
    pupil.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
  });

  // Random blinks after settle
  function scheduleRandomBlink() {
    var delay = 2000 + Math.random() * 4000;
    setTimeout(function () {
      doBlink();
      scheduleRandomBlink();
    }, delay);
  }
})();
</script>

{% layout 'theme' %}
<div style="padding:100px 40px;max-width:700px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-display);font-size:52px;letter-spacing:0.04em;margin-bottom:32px;padding-bottom:20px;border-bottom:1px solid var(--border);">{{ page.title }}</h1>
  <div style="font-size:13px;color:var(--text-2);line-height:1.9;">{{ page.content }}</div>
</div>
